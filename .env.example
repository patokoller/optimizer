# ── .env.example — AI Portfolio Decision-Support Platform ─────────────
# Copy to .env and fill in values before running locally.
# NEVER commit .env to source control.

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://portfolio:portfolio_dev@localhost:5432/portfolio_db

# ── Redis (Celery broker + backend) ───────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Anthropic Claude API ───────────────────────────────────────────────
# Required for LLM semantic scoring.
# If not set: all strategies fall back to w=1.0 (pure ML). Warning shown in UI.
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Alpaca Markets ─────────────────────────────────────────────────────
# Required for price/OHLCV data (Technical + Entropy strategies).
# If not set: Technical + Entropy blocked. Fundamental still runs.
# Use paper API key for testing: https://paper-api.alpaca.markets
ALPACA_API_KEY=YOUR_ALPACA_API_KEY
ALPACA_SECRET_KEY=YOUR_ALPACA_SECRET_KEY

# ── Alpha Vantage ─────────────────────────────────────────────────────
# Required for quarterly fundamentals (Fundamental strategy only).
# Free tier: 5 requests/minute, 500/day. Premium recommended for production.
# If not set: Fundamental strategy blocked. Technical + Entropy unaffected.
ALPHA_VANTAGE_API_KEY=YOUR_AV_KEY_HERE

# ── SEC EDGAR ──────────────────────────────────────────────────────────
# No API key needed — just a required User-Agent string per EDGAR robots.txt.
# If EDGAR unavailable: ALL strategies fall back to w=1.0.
EDGAR_USER_AGENT=ai-portfolio-platform YOUR_EMAIL@example.com

# ── Frontend ───────────────────────────────────────────────────────────
# Set in frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:8000
